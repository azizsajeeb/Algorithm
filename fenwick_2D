#include<bits/stdc++.h>
using namespace std;
int n,m;
int ar[1000][1000];
int tree[1000][1000];

int read(int x,int y){
 int sum=0; 

int y1;

 while(x>0){
    y1=y;
    while(y1>0){
        sum+=tree[x][y1];
        y1--=(y1 & -y1);
    }
    x-=(x& -x);
 }

return sum;
 
}

int query(int x1,int y1,int x2,int y2){
    
    return read(x2,y2) - read(x1-1,y2) - read(x2,y1-1) + read(x1-1,y1-1);
}

void update(int x,int y,int val){

int y1;

 while(x<=n){
    y1=y;
    while(y1<=m){
        tree[x][y1]+=val;
        y1+=(y1 & -y1);
    }
    x+=(x& -x);
 }


}


int main(){

 cin>>n>>m;
 for(int i=1;i<=n;i++){
    for(int j=1;j<=n;j++){
        cin>>ar[i][j];
        update(i,j,ar[i][j]);
    }
 }
 
 cout<<query(1,3,3,5)<<endl;

}
